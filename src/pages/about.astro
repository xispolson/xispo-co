---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About xispo — photographer, writer, gamer.">
  <div class="page-top">
    <div class="container container--narrow">
      <article class="prose">
        <h1>About</h1>
        <p>
          Hi, I'm xispo — a photographer, occasional writer, and enthusiast of all things games.
          This is where I put the things that don't fit anywhere else.
        </p>
        <p>
          I've been publishing here since 2005, which means somewhere in the archive there are
          takes I no longer hold and photos I'm not sure I should have taken.
        </p>
        <h2>Photography</h2>
        <p>
          Most of my photography lives on <a href="https://flickr.com/photos/xispo" target="_blank" rel="noopener">Flickr</a>.
          The <a href="/photos">Photos</a> page pulls from there at build time.
        </p>
        <h2>Games as a Podcast</h2>
        <p>
          A podcast about games and the industry that makes them.
          You can listen on the <a href="/podcast">Podcast</a> page, or subscribe via
          <a href="/podcast/rss.xml">RSS</a>.
        </p>
      </article>
    </div>
  </div>
</BaseLayout>
