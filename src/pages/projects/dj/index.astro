---
export const prerender = true;
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout title="DJ xis" description="DJ sets, SF events, and music from xis — active in the early 2000s San Francisco underground.">
  <div class="page-top">
    <div class="container container--narrow">

      <div class="dj-header">
        <a href="/projects" class="back-link">← Projects</a>
        <h1 class="dj-title">dj <span class="dj-title__accent">xis</span></h1>
        <p class="dj-subtitle">San Francisco, early 2000s</p>
      </div>

      <div class="dj-bio">
        <p>
         Cut my rave teeth on the East Coast, going to parties in DC (<a href="https://en.wikipedia.org/wiki/Buzz_(dance_party)" target="_blank">Buzz</a>), Baltimore
         (<a href="https://www.vice.com/en/article/a-love-letter-to-fever-the-iconic-party-that-fueled-baltimores-90s-rave-scene/" target="_blank">Fever</a>),
         Richmond and clubs in NYC (Tunnel).
         As soon as I had enough space, I cobbled together the cash for a pair of 1200s and eventually became good enough to not embarrass myself.
         Moved to SF in 1999 and got the opportunity to start djing out and about.
         I played deep house, tech house and break beats, mostly.
        </p>
      </div>

      <hr class="dj-divider" />

      <h2 class="dj-section-label">Mix</h2>

      <div class="soundcloud-wrap">
        <iframe
          width="100%"
          height="300"
          scrolling="no"
          frameborder="no"
          allow="autoplay"
          src="https://w.soundcloud.com/player/?url=https%3A//api.soundcloud.com/tracks/soundcloud%253Atracks%253A316166039&color=%23ff5500&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true&visual=true"
        ></iframe>
        <div class="soundcloud-meta">
          <a href="https://soundcloud.com/djxis" title="xis" target="_blank" rel="noopener">xis</a>
          &nbsp;·&nbsp;
          <a href="https://soundcloud.com/djxis/xis-mix-012203" title="Xis Mix 012203" target="_blank" rel="noopener">Xis Mix 012203</a>
        </div>
      </div>

      <hr class="dj-divider" />

      <h2 class="dj-section-label">Events around SF</h2>

      <div class="dj-events">

        <a href="/projects/dj/whiteout" class="event-card">
          <div class="event-card__dot event-card__dot--white"></div>
          <div class="event-card__body">
            <h3 class="event-card__name">Whiteout</h3>
            <p class="event-card__info">Fridays, 7–10pm &nbsp;·&nbsp; Sno-Drift, SF &nbsp;·&nbsp; 2001–2002</p>
            <p class="event-card__desc">
              Weekly happy hour at Sno-Drift on Third Street. An intimate, low-key
              Friday wind-down with good drinks, good music, and a regular crowd.
            </p>
            <span class="event-card__cta">View event →</span>
          </div>
        </a>

        <a href="/projects/dj/breakout" class="event-card">
          <div class="event-card__dot event-card__dot--orange"></div>
          <div class="event-card__body">
            <h3 class="event-card__name">Breakout & Console</h3>
            <p class="event-card__info">POW! Cocktail Lounge, 6th & Mission, SF</p>
            <p class="event-card__desc">
              A monthly night at POW!, one of the more eclectic spots in SoMa with
               PS2s at the bar and freaky anime on screens.
               Started as Breakout and then segued into Console. 2002-2003.
            </p>
            <span class="event-card__cta">View event →</span>
          </div>
        </a>

      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .page-top {
    padding-top: calc(var(--nav-height) + 3rem);
    padding-bottom: 4rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    color: var(--text-muted);
    font-size: var(--size-sm);
  }
  .back-link:hover { color: var(--text); text-decoration: none; }

  /* ── Header ── */
  .dj-header {
    margin-bottom: 2rem;
  }

  .dj-title {
    font-size: var(--size-5xl);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .dj-title__accent {
    color: var(--accent);
  }

  .dj-subtitle {
    color: var(--text-muted);
    font-size: var(--size-lg);
  }

  /* ── Bio ── */
  .dj-bio {
    margin-bottom: 2.5rem;
  }

  .dj-bio p {
    color: var(--text-muted);
    line-height: 1.75;
    font-style: italic;
    border-left: 3px solid var(--border);
    padding-left: 1rem;
  }

  /* ── Dividers & section labels ── */
  .dj-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  .dj-section-label {
    font-size: var(--size-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  /* ── SoundCloud ── */
  .soundcloud-wrap {
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--bg-card);
    border: 1px solid var(--border);
    margin-bottom: 0.25rem;
  }

  .soundcloud-meta {
    font-size: var(--size-xs);
    color: var(--text-faint);
    padding: 0.5rem 0.75rem;
    font-family: var(--font-sans);
    border-top: 1px solid var(--border);
  }

  .soundcloud-meta a {
    color: var(--text-muted);
  }
  .soundcloud-meta a:hover { color: var(--text); }

  /* ── Events intro ── */
  .dj-events-intro {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  /* ── Event cards ── */
  .dj-events {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .event-card {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    color: var(--text);
    transition: border-color 0.15s;
  }
  .event-card:hover {
    border-color: var(--accent-dim);
    text-decoration: none;
  }

  .event-card__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 0.45rem;
  }
  .event-card__dot--white  { background: #e8e8e8; }
  .event-card__dot--orange { background: #ff6a00; }
  .event-card__dot--yellow { background: #ffcc66; }

  .event-card__name {
    font-size: var(--size-xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.25rem;
  }

  .event-card__info {
    font-size: var(--size-xs);
    color: var(--text-muted);
    letter-spacing: 0.04em;
    margin-bottom: 0.75rem;
    font-family: var(--font-mono);
  }

  .event-card__desc {
    font-size: var(--size-sm);
    color: var(--text-muted);
    line-height: 1.65;
    margin-bottom: 0.75rem;
  }

  .event-card__cta {
    font-size: var(--size-sm);
    color: var(--accent);
    font-weight: 500;
  }

  @media (max-width: 480px) {
    .dj-title { font-size: var(--size-4xl); }
  }
</style>
