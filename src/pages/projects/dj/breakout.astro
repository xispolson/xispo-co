---
export const prerender = true;
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout title="Breakout & Console" description="Breakout and Console — DJ nights with Xis & Pete Za at POW! Cocktail Lounge, 101 6th St @ Mission, San Francisco. 2002–2003.">
  <div class="page-top">
    <div class="container container--narrow">

      <div class="event-header">
        <a href="/projects/dj" class="back-link">← DJ</a>
        <div class="event-dot"></div>
        <h1 class="event-title">Breakout &amp; Console</h1>
        <p class="event-meta">POW! Cocktail Lounge &nbsp;·&nbsp; 101 6th St @ Mission, SF &nbsp;·&nbsp; 2002–2003</p>
      </div>

      <div class="events">

        <!-- ── Breakout ── -->
        <div class="event-section">
          <h2 class="event-section__title">Breakout</h2>
          <div class="flyer-wrap">
            <button class="flyer-trigger"
              data-src="/images/dj/breakout-flyer.jpg"
              data-alt="Breakout @ POW! — DJs Xis & Pete 2A, Saturday March 8th, 9:30pm–2am, 101 6th St @ Mission. No cover."
              aria-label="View Breakout flyer full size"
            >
              <img
                src="/images/dj/breakout-flyer.jpg"
                alt="Breakout @ POW! — DJs Xis & Pete 2A, Saturday March 8th, 9:30pm–2am, 101 6th St @ Mission. No cover."
                class="flyer"
              />
              <span class="expand-hint" aria-hidden="true">&#x2922;</span>
            </button>
          </div>
        </div>

        <!-- ── Console ── -->
        <div class="event-section">
          <h2 class="event-section__title">Console</h2>
          <div class="flyer-wrap">
            <button class="flyer-trigger"
              data-src="/images/dj/console/console_flyer_restored.png"
              data-alt="Console — Resident DJs Xis and Pete Za + special guests. Beeps and beats with the finest sounds of tech house and dirty breaks. No cover. Fourth Saturday of every month @ P.O.W. (Mission & 6th). 9:30pm–2am."
              aria-label="View Console flyer full size"
            >
              <img
                src="/images/dj/console/console_flyer_restored.png"
                alt="Console — Resident DJs Xis and Pete Za + special guests."
                class="flyer"
              />
              <span class="expand-hint" aria-hidden="true">&#x2922;</span>
            </button>
          </div>
        </div>

      </div>

    </div>
  </div>

  <!-- ── Lightbox ── -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Flyer full view" hidden>
    <button class="lightbox-close" id="lightboxClose" aria-label="Close">&times;</button>
    <div class="lightbox-backdrop" id="lightboxBackdrop"></div>
    <div class="lightbox-content">
      <img class="lightbox-img" id="lightboxImg" src="" alt="" />
    </div>
  </div>
</BaseLayout>

<style>
  .page-top {
    padding-top: calc(var(--nav-height) + 3rem);
    padding-bottom: 4rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    color: var(--text-muted);
    font-size: var(--size-sm);
  }
  .back-link:hover { color: var(--text); text-decoration: none; }

  .event-header { margin-bottom: 3rem; }

  .event-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #ff6a00;
    margin-bottom: 1rem;
  }

  .event-title {
    font-size: var(--size-5xl);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .event-meta {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    color: var(--text-muted);
    letter-spacing: 0.06em;
  }

  /* ── Two-column layout ── */
  .events {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .event-section__title {
    font-size: var(--size-sm);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  /* ── Flyers ── */
  .flyer-wrap {
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,0.45);
  }

  .flyer-trigger {
    position: relative;
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: none;
    cursor: zoom-in;
  }

  .flyer {
    display: block;
    width: 100%;
    height: auto;
    transition: opacity 0.2s;
  }

  .flyer-trigger:hover .flyer { opacity: 0.88; }

  .expand-hint {
    position: absolute;
    bottom: 0.5rem;
    right: 0.5rem;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 4px;
    background: rgba(0,0,0,0.55);
    color: #fff;
    font-size: 0.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.15s;
    pointer-events: none;
  }

  .flyer-trigger:hover .expand-hint,
  .flyer-trigger:focus-visible .expand-hint { opacity: 1; }

  /* ── Lightbox ── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox[hidden] { display: none; }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    cursor: zoom-out;
  }

  .lightbox-content {
    position: relative;
    z-index: 1;
    max-width: min(90vw, 1000px);
    max-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-img {
    display: block;
    max-width: 100%;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius-sm);
    box-shadow: 0 0 60px rgba(0,0,0,0.6);
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 2;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }

  .lightbox-close:hover { background: rgba(255,255,255,0.22); }

  @media (max-width: 640px) {
    .event-title { font-size: var(--size-4xl); }
    .events { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>

<script>
  const lightbox   = document.getElementById('lightbox')         as HTMLElement | null;
  const lbImg      = document.getElementById('lightboxImg')      as HTMLImageElement | null;
  const lbClose    = document.getElementById('lightboxClose')    as HTMLButtonElement | null;
  const lbBackdrop = document.getElementById('lightboxBackdrop') as HTMLElement | null;

  function openLightbox(src: string, alt: string) {
    if (!lightbox || !lbImg) return;
    lbImg.src = src;
    lbImg.alt = alt;
    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';
    lbClose?.focus();
  }

  function closeLightbox() {
    if (!lightbox) return;
    lightbox.hidden = true;
    document.body.style.overflow = '';
    lbImg && (lbImg.src = '');
  }

  document.querySelectorAll<HTMLButtonElement>('.flyer-trigger').forEach(btn => {
    btn.addEventListener('click', () => openLightbox(btn.dataset.src ?? '', btn.dataset.alt ?? ''));
  });

  lbClose?.addEventListener('click', closeLightbox);
  lbBackdrop?.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && lightbox && !lightbox.hidden) closeLightbox();
  });
</script>
