---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Projects" description="Side projects and experiments by xispo.">
  <div class="page-top">
    <div class="container">
      <div class="section__header">
        <h1 class="section__title">Projects</h1>
      </div>
      <div class="projects-grid">
        <a href="/projects/moo-deng" class="project-card">
          <div class="project-card__img-wrap">
            <img src="/images/moo-deng/moo-deng.jpg" alt="Moo Deng the pygmy hippo" />
          </div>
          <div class="project-card__body">
            <h2 class="project-card__title">Moo Deng Me</h2>
            <p class="project-card__desc">Generate a motivational poster starring Moo Deng, the world's most famous pygmy hippo. Pair a random photo with an inspirational quote and save it as a PNG.</p>
            <span class="project-card__cta">Launch app →</span>
          </div>
        </a>

        <a href="/projects/dj" class="project-card">
          <div class="project-card__img-wrap project-card__img-wrap--dark">
            <div class="project-card__dj-hero">
              <span class="project-card__dj-label">dj xis</span>
            </div>
          </div>
          <div class="project-card__body">
            <h2 class="project-card__title">dj xis</h2>
            <p class="project-card__desc">Three SF events from the early 2000s — Whiteout, Breakout, and Console — plus a recorded mix from 2003.</p>
            <span class="project-card__cta">View →</span>
          </div>
        </a>

        {/* edgeglider card — commented out until ready
        <a href="/projects/edgeglider" class="project-card">
          <div class="project-card__img-wrap">
            <img src="/images/edgeglider/home.jpg" alt="edgeglider.com splash page" />
          </div>
          <div class="project-card__body">
            <h2 class="project-card__title">edgeglider.com</h2>
            <p class="project-card__desc">A time capsule of my first personal website, hand-coded in HTML 4.0 and active from 2001 to 2004. Table layouts, image maps, and all.</p>
            <span class="project-card__cta">View archive →</span>
          </div>
        </a>
        */}

      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color 0.15s;
    color: var(--text);
  }
  .project-card:hover {
    border-color: var(--accent-dim);
    text-decoration: none;
  }

  .project-card__img-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }
  .project-card__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .project-card:hover .project-card__img-wrap img {
    transform: scale(1.03);
  }

  .project-card__body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .project-card__title {
    font-size: var(--size-xl);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .project-card__desc {
    font-size: var(--size-sm);
    color: var(--text-muted);
    line-height: 1.6;
    flex: 1;
  }

  .project-card__cta {
    margin-top: 0.5rem;
    font-size: var(--size-sm);
    color: var(--accent);
    font-weight: 500;
  }

  .project-card__img-wrap--dark {
    background: #0a0a0a;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .project-card__dj-hero {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .project-card__dj-label {
    font-family: var(--font-mono);
    font-size: var(--size-2xl);
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.08em;
    opacity: 0.85;
  }
</style>
