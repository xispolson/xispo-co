---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import type { FlickrPhoto } from '../lib/flickr';

// Photos pre-fetched by scripts/fetch-hero.mjs before astro build runs.
let photos: FlickrPhoto[] = [];
try {
  const mod = await import('../data/photos.json').catch(() => null);
  photos = (mod?.default ?? []) as FlickrPhoto[];
} catch {
  // photos stays empty → empty state renders
}
---

<BaseLayout title="Photos" description="A selection of photographs by xispo.">
  <div class="page-top">
    <div class="container">
      <div class="section__header">
        <h1 class="section__title">Photos</h1>
        {photos.length > 0 && (
          <span class="text-muted" style="margin-left: auto; font-size: var(--size-sm);">
            {photos.length} photos · <a href="https://flickr.com/photos/xispo" target="_blank" rel="noopener">Flickr</a>
          </span>
        )}
      </div>

      {photos.length === 0 ? (
        <p class="text-muted">No photos available right now.</p>
      ) : (
        <div class="photo-grid">
          {photos.map(photo => (
            <a
              class="photo-grid__item"
              href={`https://www.flickr.com/photos/xispo/${photo.id}`}
              target="_blank"
              rel="noopener"
              title={photo.title}
            >
              <img
                src={photo.url_c}
                alt={photo.title || ''}
                loading="lazy"
                decoding="async"
              />
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</BaseLayout>
