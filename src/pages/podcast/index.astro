---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate, isoDate, truncate } from '../../lib/utils';

const episodes = (await getCollection('podcast', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const PODCAST_NAME = 'Games as a Podcast';
const PODCAST_DESC = 'Jabbering about games and the industry that makes them.';
const PODCAST_ARTWORK = '/podcast/artwork.jpg';
const PODCAST_PROMO = '/podcast/promo/GaaP_podcast_promo-FINAL.jpg';
const SPOTIFY_URL = 'https://open.spotify.com/show/7eGC4gpJuHLphu1MP5jxgn?si=f2e31449b1be41a4';
const APPLE_URL = 'https://podcasts.apple.com/us/podcast/games-as-a-podcast/id1816797200';
---

<BaseLayout
  title={PODCAST_NAME}
  description={PODCAST_DESC}
>
  <!-- Full-width promo banner -->
  <div class="podcast-banner">
    <img
      class="podcast-banner__img"
      src={PODCAST_PROMO}
      alt={PODCAST_NAME}
      loading="eager"
    />
    <div class="podcast-banner__overlay" />
    <div class="podcast-banner__content container">
      <div class="podcast-banner__inner">
        <img
          class="podcast-hero__artwork"
          src={PODCAST_ARTWORK}
          alt={`${PODCAST_NAME} artwork`}
          width="120"
          height="120"
          onerror="this.style.display='none'"
        />
        <div>
          <h1 class="podcast-hero__title">{PODCAST_NAME}</h1>
          <p class="podcast-hero__desc">{PODCAST_DESC}</p>
          <div class="podcast-hero__links">
            <a href={SPOTIFY_URL} target="_blank" rel="noopener" class="btn btn--accent">Spotify</a>
            <a href={APPLE_URL} target="_blank" rel="noopener" class="btn">Apple Podcasts</a>
            <a href="/podcast/rss.xml" class="btn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
              </svg>
              RSS
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="container" style="padding-bottom: 4rem;">
    {episodes.length === 0 ? (
      <p class="text-muted">No episodes yet. Check back soon.</p>
    ) : (
      <div class="episodes-grid">
        {episodes.map(ep => (
          <article class="episode-card">
            <a href={`/podcast/${ep.id}`} class="episode-card__thumb" aria-hidden="true" tabindex="-1">
              <img
                src={ep.data.artwork ?? '/podcast/artwork.jpg'}
                alt=""
                width="96"
                height="96"
                loading="lazy"
                onerror="this.src='/podcast/artwork.jpg'"
              />
            </a>
            <div>
              <div class="episode-card__meta" style="margin-top: 0; margin-bottom: 0.35rem;">
                {ep.data.episodeNumber != null && (
                  <span style="color: var(--accent); font-weight: 600;">
                    Ep. {ep.data.episodeNumber}
                  </span>
                )}
                <time datetime={isoDate(ep.data.date)}>{formatDate(ep.data.date)}</time>
                {ep.data.duration && <span>{ep.data.duration}</span>}
              </div>
              <h2 class="episode-card__title">
                <a href={`/podcast/${ep.id}`}>{ep.data.title}</a>
              </h2>
              <p class="episode-card__desc">{truncate(ep.data.description, 220)}</p>
              <div class="audio-player" style="margin-top: 0.75rem;">
                <audio controls preload="none">
                  <source src={ep.data.audioUrl} type="audio/mpeg" />
                  Your browser does not support audio playback.
                </audio>
              </div>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
