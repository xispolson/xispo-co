# Flickr API
# Get your key at: https://www.flickr.com/services/apps/create/
FLICKR_API_KEY=your_api_key_here

# Your Flickr NSID (numeric user ID, e.g. 12345678@N00)
# Find it at: https://www.flickr.com/services/api/explore/flickr.people.findByUsername
FLICKR_USER_ID=your_user_id_here

# Optional: pull photos from a specific album instead of all public photos
# Get the photoset ID from the album URL: flickr.com/photos/xispo/sets/XXXXXXXXXX
FLICKR_ALBUM_ID=

# Keystatic (for GitHub mode in production — leave empty for local mode)
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=
# KEYSTATIC_SECRET=
